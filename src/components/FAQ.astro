---
import { CONFIG } from '../config'

interface Props {
  faqs?: { q: string; a: string }[]
  eyebrow?: string
  headline?: string
  subheadline?: string
}

const {
  faqs = CONFIG.faqs,
  eyebrow = 'FAQ',
  headline = 'Questions We Hear a Lot',
  subheadline,
} = Astro.props

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
}
---

<section class="py-16 md:py-24 bg-white">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div data-reveal class="text-center mb-10">
      <p class="text-warm-500 text-sm font-semibold tracking-widest uppercase mb-3">{eyebrow}</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-stone-900 mb-3">
        {headline}
      </h2>
      <p class="text-stone-500">
        {subheadline ?? "Quick answers to the things folks ask us most. Don't see yours?"}
        {' '}
        <a href={CONFIG.cta.call.href} class="text-warm-600 font-semibold no-underline hover:text-warm-700">
          Give us a call
        </a>.
      </p>
    </div>

    <div data-reveal class="space-y-3">
      {
        faqs.map((faq) => (
          <details class="group bg-warm-50 border border-warm-100 rounded-xl overflow-hidden transition-all hover:border-warm-200">
            <summary class="flex items-center justify-between gap-4 cursor-pointer px-5 py-4 list-none font-semibold text-stone-800 [&::-webkit-details-marker]:hidden">
              <span class="text-base md:text-lg">{faq.q}</span>
              <svg
                class="w-5 h-5 shrink-0 text-warm-500 transition-transform duration-200 group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-1 text-stone-600 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
