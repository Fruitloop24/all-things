---
import { CONFIG } from '../config'

const path = Astro.url.pathname
const isActive = (to: string) =>
  to === '/' ? path === '/' : path === to || path.startsWith(to + '/')

type NavItem = { to: string; label: string; iconKey: 'home' | 'studio' | 'resources' | 'call' }

const items: NavItem[] = [
  { to: '/', label: 'Home', iconKey: 'home' },
  { to: '/studio', label: 'Studio', iconKey: 'studio' },
  { to: '/resources', label: 'Resources', iconKey: 'resources' },
  { to: CONFIG.phone.href, label: 'Call', iconKey: 'call' },
]

const icons = {
  home: 'M2.25 12l8.954-8.955a1.126 1.126 0 011.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25',
  studio:
    'M9.53 16.122a3 3 0 00-5.78 1.128 2.25 2.25 0 01-2.4 2.245 4.5 4.5 0 008.4-2.245c0-.399-.078-.78-.22-1.128zm0 0a15.998 15.998 0 003.388-1.62m-5.043-.025a15.994 15.994 0 011.622-3.395m3.42 3.42a15.995 15.995 0 004.764-4.648l3.876-5.814a1.151 1.151 0 00-1.597-1.597L14.146 6.32a15.996 15.996 0 00-4.649 4.763m3.42 3.42a6.776 6.776 0 00-3.42-3.42',
  resources:
    'M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H3.75A2.25 2.25 0 001.5 6.75v12a2.25 2.25 0 002.25 2.25z',
  call: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z',
}
---

<nav class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-t border-warm-200 shadow-[0_-4px_6px_-1px_rgba(0,0,0,0.05)]">
  <div class="flex items-center justify-around h-16">
    {
      items.map(({ to, label, iconKey }) => {
        const external = to.startsWith('tel:') || to.startsWith('mailto:')
        const active = !external && isActive(to)
        return (
          <a
            href={to}
            class:list={[
              'flex flex-col items-center gap-1 transition-colors no-underline',
              active ? 'text-warm-700' : 'text-stone-500 hover:text-warm-700',
            ]}
          >
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icons[iconKey]} />
            </svg>
            <span class="text-[10px] font-medium">{label}</span>
          </a>
        )
      })
    }
  </div>
</nav>
