---
import { CONFIG } from '../config'

const email = CONFIG.cta.email.href.replace(/^mailto:/, '')

const cities = [
  'Eastman',
  'McRae-Helena',
  'Cochran',
  'Hawkinsville',
  'Chauncey',
  'Dublin',
  'Rhine',
  'Milan',
  'Cadwell',
  'Abbeville',
]
const counties = [
  'Dodge County',
  'Telfair County',
  'Pulaski County',
  'Laurens County',
  'Wilcox County',
  'Bleckley County',
]

const sameAs = CONFIG.socials
  .filter((s) => s.href && s.href !== '#')
  .map((s) => s.href)

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': new URL('/#business', Astro.site).toString(),
  name: CONFIG.appName,
  image: new URL('/pwa-512.png', Astro.site).toString(),
  logo: CONFIG.images.logoTransparent,
  telephone: CONFIG.phone.display,
  email,
  url: Astro.site?.toString(),
  ...(sameAs.length > 0 && { sameAs }),
  address: {
    '@type': 'PostalAddress',
    streetAddress: CONFIG.address.street,
    addressLocality: CONFIG.address.city,
    addressRegion: CONFIG.address.state,
    postalCode: CONFIG.address.zip,
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 32.1965,
    longitude: -83.1763,
  },
  areaServed: [
    ...cities.map((name) => ({ '@type': 'City', name })),
    ...counties.map((name) => ({ '@type': 'AdministrativeArea', name })),
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '08:00',
      closes: '16:00',
    },
  ],
  priceRange: '$$',
  description: CONFIG.hero.subheadline,
  foundingDate: String(CONFIG.yearStarted),
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
