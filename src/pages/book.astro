---
import Base from '../layouts/Base.astro'
import BookingForm from '../components/BookingForm'
import { CONFIG } from '../config'

const ronFirst = CONFIG.team.management[0].name.split(' ')[0]
const jamieFirst = CONFIG.team.management[1].name.split(' ')[0]
---

<Base
  title="Book a Free Estimate"
  description="Schedule your free in-home flooring estimate in Eastman, GA and surrounding areas. Pick a time that works — we'll come measure and lock in your price.">
  <section class="bg-gradient-to-b from-warm-100 to-warm-50 border-b border-warm-200 py-12 md:py-16 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-warm-700 text-xs font-semibold tracking-widest uppercase mb-2">Free &middot; No-Obligation</p>
      <h1 class="font-heading text-3xl md:text-5xl font-bold text-warm-900 mb-3">
        Book a Free Estimate
      </h1>
      <p class="text-stone-600 text-base md:text-lg leading-relaxed max-w-xl mx-auto">
        Tell us about your project and pick a time. {ronFirst} or {jamieFirst} will come measure your space and lock in your price — no pressure, no hidden fees.
      </p>
    </div>
  </section>

  <section class="py-10 md:py-14 bg-warm-50">
    <div class="max-w-2xl mx-auto px-4 sm:px-6">
      <BookingForm client:load />
    </div>
  </section>

  <section class="py-12 bg-white border-t border-warm-100 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="font-heading text-xl md:text-2xl font-bold text-stone-900 mb-2">Rather just talk?</h2>
      <p class="text-stone-500 mb-6 text-sm md:text-base">We book estimates {CONFIG.bookingApi.hoursLabel}. Call or text {ronFirst} anytime.</p>
      <a
        href={CONFIG.phone.href}
        class="inline-flex items-center gap-2 bg-warm-700 hover:bg-warm-800 text-white px-6 py-3 rounded-xl font-semibold no-underline shadow-md transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
        </svg>
        Call {CONFIG.phone.display}
      </a>
    </div>
  </section>
</Base>
