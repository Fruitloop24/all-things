---
import Base from '../layouts/Base.astro'
import Studio from '../components/Studio'
import FAQ from '../components/FAQ.astro'
import { CONFIG } from '../config'
---

<Base title="Design Studio" description="Visualize new floors in your room with AI, or get an instant cost estimate with our calculator.">
  <section class="bg-gradient-to-b from-warm-100 to-warm-50 border-b border-warm-200 py-8 md:py-10 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-warm-700 text-xs font-semibold tracking-widest uppercase mb-2">Design Studio</p>
      <h1 class="font-heading text-2xl md:text-4xl font-bold text-warm-900 mb-2">
        AI Flooring Visualizer &amp; Cost Calculator
      </h1>
      <p class="text-stone-600 text-sm md:text-base leading-relaxed max-w-xl mx-auto">
        Upload a photo of your room, pick a floor, and see it instantly — or get a free cost estimate for hardwood, tile, vinyl, and carpet in Eastman, GA.
      </p>
    </div>
  </section>
  <Studio client:load />

  <FAQ
    faqs={CONFIG.studioFaqs}
    eyebrow="Studio FAQ"
    headline="About the Visualizer & Calculator"
    subheadline="The most common questions about our AI tools. Don't see yours?"
  />
</Base>
