---
import Base from '../layouts/Base.astro'
import { CONFIG } from '../config'

const { community, cta } = CONFIG
const activeSocials = CONFIG.socials.filter((s) => s.href && s.href !== '#')
const fbGroupActive = CONFIG.facebookGroup && CONFIG.facebookGroup !== '#'

const NAV_LINKS = [
  { href: '#involvement', label: 'Giving Back' },
  { href: '#events', label: 'Events' },
  { href: '#connect', label: 'Connect' },
]
---

<Base title="Community" description="All Things Flooring & Tile is proud to be part of the fabric of Dodge County. Churches, youth sports, Habitat for Humanity, and more.">
  <section class="relative bg-gradient-to-br from-warm-900 via-warm-800 to-warm-700 text-white py-16 md:py-20 text-center overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_20%_80%,rgba(192,133,82,0.4),transparent_50%),radial-gradient(circle_at_80%_20%,rgba(255,255,255,0.15),transparent_40%)]"></div>
    <div class="relative max-w-3xl mx-auto px-4">
      <p class="text-warm-300 text-sm font-semibold tracking-widest uppercase mb-3">Dodge County</p>
      <h1 class="font-heading text-3xl md:text-5xl font-bold mb-4">{community.headline}</h1>
      <p class="text-warm-200/90 text-lg leading-relaxed max-w-xl mx-auto mb-8">{community.subheadline}</p>

      <div class="flex flex-wrap justify-center gap-3">
        {
          NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white px-5 py-2 rounded-full text-sm font-semibold transition-all no-underline border border-white/15"
            >
              {link.label}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section id="involvement" class="py-16 bg-warm-50 scroll-mt-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-warm-500 text-sm font-semibold tracking-widest uppercase mb-2">Giving Back</p>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900">Rooted in Dodge County</h2>
        <p class="text-stone-500 mt-2 max-w-lg mx-auto">From the sanctuary to the schoolhouse, we show up for our community.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {
          community.involvement.map((item, i) => (
            <div
              class="bg-white rounded-2xl p-6 border-l-4 shadow-sm hover:shadow-md transition-all hover:-translate-y-1"
              style={`border-left-color: ${i % 2 === 0 ? '#c08552' : '#6b472e'};`}
            >
              <div
                class="w-12 h-12 rounded-xl flex items-center justify-center text-2xl mb-4"
                style={`background: ${i % 2 === 0 ? 'rgba(192,133,82,0.12)' : 'rgba(107,71,46,0.1)'};`}
              >
                {item.icon}
              </div>
              <h3 class="font-heading text-lg font-bold text-stone-900 mb-2">{item.title}</h3>
              <p class="text-stone-500 text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-warm-900 py-14 text-center relative overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-5">
      <span class="font-heading text-[12rem] text-white absolute top-[-20px] left-1/2 -translate-x-1/2">&ldquo;</span>
    </div>
    <div class="relative max-w-3xl mx-auto px-4">
      <blockquote class="font-heading text-xl md:text-2xl text-white/90 italic leading-relaxed mb-4">
        &ldquo;{community.quote}&rdquo;
      </blockquote>
      <cite class="text-warm-300 text-sm font-medium not-italic">&mdash; {community.quoteAuthor}</cite>
    </div>
  </section>

  <section id="events" class="py-16 bg-white scroll-mt-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-10">
        <p class="text-warm-500 text-sm font-semibold tracking-widest uppercase mb-2">What's Coming</p>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900">Events &amp; Drives</h2>
        <p class="text-stone-500 mt-2 max-w-lg mx-auto">Catch us around town — here's where we'll be this year.</p>
      </div>

      <div class="relative pl-8 border-l-[3px] border-warm-500">
        {
          community.events.map((evt, i) => (
            <div class="relative pb-10 last:pb-0">
              <div
                class="absolute -left-[calc(2rem+7px)] w-[14px] h-[14px] rounded-full border-[3px] top-1"
                style={`background: ${i % 2 === 0 ? '#c08552' : '#6b472e'}; border-color: #ffffff; box-shadow: 0 0 0 3px ${i % 2 === 0 ? '#c08552' : '#6b472e'};`}
              ></div>
              <div class="bg-warm-50 rounded-xl p-5 hover:shadow-md transition-shadow">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-2xl">{evt.icon}</span>
                  <span
                    class="text-xs font-bold uppercase tracking-widest"
                    style={`color: ${i % 2 === 0 ? '#c08552' : '#6b472e'};`}
                  >
                    {evt.date}
                  </span>
                </div>
                <h3 class="font-heading text-lg font-bold text-stone-900 mb-1">{evt.title}</h3>
                <p class="text-stone-500 text-sm leading-relaxed">{evt.desc}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section id="connect" class="py-16 bg-warm-50 scroll-mt-20">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm border border-warm-100">
        <div class="w-16 h-16 bg-warm-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
          <svg class="w-8 h-8 text-warm-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />
          </svg>
        </div>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900 mb-3">Drop Us a Line</h2>
        <p class="text-stone-500 mb-6 leading-relaxed">
          Got a project idea, want to sponsor a team, or just want to say hey? We'd love to hear from you. Follow us, join our Facebook group, and stay connected with everything happening at All Things Flooring &amp; Tile.
        </p>

        {activeSocials.length > 0 && (
          <div class="mb-6">
            <p class="text-[11px] font-semibold uppercase tracking-widest text-stone-400 mb-3">Follow All Things</p>
            <div class="flex items-center justify-center gap-3">
              {activeSocials.map((s) => (
                <a
                  href={s.href}
                  target="_blank"
                  rel="noopener noreferrer me"
                  aria-label={`Follow us on ${s.name}`}
                  title={`${s.name} — ${s.handle}`}
                  class="connect-social w-12 h-12 rounded-xl bg-stone-50 border border-stone-200 flex items-center justify-center transition-all hover:-translate-y-0.5 active:scale-95"
                  style={`--brand: ${s.brandColor};`}
                >
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path d={s.icon} />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          {fbGroupActive ? (
            <a
              href={CONFIG.facebookGroup}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 bg-[#1877F2] hover:bg-[#1565c0] text-white px-6 py-3 rounded-xl font-semibold transition-all no-underline shadow-md"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
              </svg>
              Join Our Facebook Group
            </a>
          ) : (
            <a
              href={cta.email.href}
              class="inline-flex items-center justify-center gap-2 bg-warm-700 hover:bg-warm-800 text-white px-6 py-3 rounded-xl font-semibold transition-all no-underline shadow-md"
            >
              {cta.email.text}
            </a>
          )}
          <a
            href={cta.call.href}
            class="inline-flex items-center justify-center gap-2 border-2 border-warm-300 text-warm-700 hover:bg-warm-100 px-6 py-3 rounded-xl font-semibold transition-all no-underline"
          >
            {cta.call.text}
          </a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .connect-social {
      color: #6b472e;
    }
    .connect-social:hover {
      background-color: var(--brand);
      border-color: var(--brand);
      color: #fff;
      box-shadow: 0 10px 25px -10px var(--brand);
    }
  </style>

  <section class="py-16 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <p class="text-warm-500 text-sm font-semibold tracking-widest uppercase mb-2">Find Us</p>
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900">Stop By the Showroom</h2>
        <p class="text-stone-500 mt-2 max-w-lg mx-auto">{CONFIG.address.full}</p>
      </div>
      <div class="rounded-2xl overflow-hidden shadow-md border border-warm-200">
        <iframe
          src={CONFIG.mapEmbed}
          title={`Map to ${CONFIG.appName} showroom`}
          width="100%"
          height="350"
          style="border: 0; display: block;"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen
        ></iframe>
      </div>
      <div class="text-center mt-5">
        <a
          href={CONFIG.mapDirections}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 bg-warm-700 hover:bg-warm-800 text-white px-5 py-2.5 rounded-xl font-semibold text-sm transition-all no-underline shadow-md"
        >
          Get Directions
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-warm-50 text-center">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="font-heading text-2xl md:text-3xl font-bold text-stone-900 mb-3">Want to Partner With Us?</h2>
      <p class="text-stone-500 mb-8">Whether you need a sponsor, help with a church renovation, or just want to connect — we'd love to hear from you.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={cta.email.href}
          class="inline-flex items-center justify-center gap-2 bg-warm-700 hover:bg-warm-800 text-white px-8 py-4 rounded-xl font-semibold transition-all no-underline shadow-md"
        >
          {cta.email.text}
        </a>
        <a
          href={cta.call.href}
          class="inline-flex items-center justify-center gap-2 border-2 border-warm-300 text-warm-700 hover:bg-warm-100 px-8 py-4 rounded-xl font-semibold transition-all no-underline"
        >
          {cta.call.text}
        </a>
      </div>
    </div>
  </section>
</Base>
